from fastapi import FastAPI, Query, Request
import requests
import hashlib
import json

app = FastAPI()

BASE_URL = "https://100067.connect.garena.com"
APP_ID = "100067"
SEC_CODE = "123456"

def get_clean_headers(request: Request):
    # Mobile signature simulation
    ua = request.headers.get("user-agent", "GarenaMSDK/4.0.39 (M2007J22C; Android 10; en; US;)")
    return {
        "User-Agent": ua,
        "Content-Type": "application/x-www-form-urlencoded",
        "Accept-Encoding": "gzip",
        "Connection": "keep-alive"
    }

def sha256_hash(s: str):
    return hashlib.sha256(s.encode()).hexdigest()

# --- Internal: Get Account Bind Status ---
def get_status(token, headers):
    params = {"app_id": APP_ID, "access_token": token}
    r = requests.get(f"{BASE_URL}/game/account_security/bind:get_bind_info", params=params, headers=headers)
    return r.json()

# --- Internal: Verify Identity (Returns Token) ---
def get_identity_token(token, headers):
    data = {
        "app_id": APP_ID,
        "access_token": token,
        "secondary_password": sha256_hash(SEC_CODE)
    }
    r = requests.post(f"{BASE_URL}/game/account_security/bind:verify_identity", data=data, headers=headers)
    res = r.json()
    return res.get("identity_token"), res

# --- Internal: Verify OTP (Returns Verifier) ---
def get_verifier_token(token, email, otp, headers):
    data = {
        "app_id": APP_ID,
        "access_token": token,
        "email": email,
        "otp": otp
    }
    r = requests.post(f"{BASE_URL}/game/account_security/bind:verify_otp", data=data, headers=headers)
    res = r.json()
    return res.get("verifier_token"), res

# --- ROUTES ---

@app.get("/api/request")
async def request_otp(request: Request, token: str, email: str):
    headers = get_clean_headers(request)
    
    # Check if account is BD or other
    payload = {
        "app_id": APP_ID,
        "access_token": token,
        "email": email,
        "locale": "en_BD",
        "region": "BD"
    }
    r = requests.post(f"{BASE_URL}/game/account_security/bind:send_otp", data=payload, headers=headers)
    return {"status": "OTP Sent", "garena_res": r.json()}

@app.get("/api/confirm")
async def confirm_bind(request: Request, token: str, email: str, otp: str):
    headers = get_clean_headers(request)
    
    # 1. Check current bind status (Bahut zaroori hai error param se bachne ke liye)
    status_res = get_status(token, headers)
    current_email = status_res.get("email") # Agar mail hai toh rebind hoga

    # 2. Verify OTP to get Verifier Token
    v_token, v_raw = get_verifier_token(token, email, otp, headers)
    if not v_token:
        return {"error": "OTP Verification Failed", "garena_msg": v_raw}

    # 3. Final Binding Call
    if current_email:
        # REBIND FLOW (Requires Identity Token)
        id_token, id_raw = get_identity_token(token, headers)
        if not id_token:
            return {"error": "Identity Token Failed (Security Code 123456 wrong or not set)", "garena_msg": id_raw}
        
        final_payload = {
            "app_id": APP_ID,
            "access_token": token,
            "identity_token": id_token,
            "verifier_token": v_token,
            "email": email
        }
        endpoint = "/game/account_security/bind:create_rebind_request"
    else:
        # NEW BIND FLOW (Does NOT require Identity Token)
        final_payload = {
            "app_id": APP_ID,
            "access_token": token,
            "verifier_token": v_token,
            "email": email
        }
        endpoint = "/game/account_security/bind:create_bind_request"

    # 4. Hit Garena
    r = requests.post(f"{BASE_URL}{endpoint}", data=final_payload, headers=headers)
    return {
        "type": "REBIND" if current_email else "NEW_BIND",
        "result": r.json()
    }

@app.get("/api/cancel")
async def cancel(request: Request, token: str):
    headers = get_clean_headers(request)
    r = requests.post(f"{BASE_URL}/game/account_security/bind:cancel_request", 
                      data={"app_id": APP_ID, "access_token": token}, headers=headers)
    return r.json()
